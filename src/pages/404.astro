---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="404 — page not found"
  description="That page doesn't exist."
>
  <div class="container" style="text-align: center; padding-top: 40px;">
    <span class="eyebrow">404</span>
    <h1>This page slipped through the cracks.</h1>
    <p class="lede">
      Whatever you were looking for isn't here. Try the
      <a href="/">homepage</a>, the <a href="/privacy">privacy policy</a>,
      or get in touch at <a href="mailto:help@turnaphrase.app">help@turnaphrase.app</a>.
    </p>
  </div>
</BaseLayout>
